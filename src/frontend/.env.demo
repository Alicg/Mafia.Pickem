VITE_DEMO=true
# Browser runtime base: where the browser should send API requests.
VITE_BROWSER_API_BASE_URL=http://localhost:7071/api
# Browser runtime base: where the browser should send blob requests.
VITE_BROWSER_BLOB_BASE_URL=http://127.0.0.1:10000/devstoreaccount1/match-states
# Dev proxy target: where Vite should forward browser /api requests.
VITE_DEV_PROXY_API_TARGET=http://localhost:7071
# Dev proxy target: where Vite should forward browser /blob requests.
VITE_DEV_PROXY_BLOB_TARGET=http://127.0.0.1:10000
VITE_DEV_PROXY_BLOB_ACCOUNT=devstoreaccount1
VITE_DEV_PROXY_BLOB_CONTAINER=match-states
