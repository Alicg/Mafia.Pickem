{
  // Конфигурация глобального .NET SDK для всего проекта
  "sdk": {
    // Обязательная версия SDK: 9.0.300
    // Все разработчики и CI/CD будут использовать эту версию
    "version": "9.0.300",
    
    // Стратегия выбора версии SDK:
    // - "latestFeature" позволяет использовать более новые версии в рамках 9.0.x
    //   (например, 9.0.301, 9.0.302 и т.д.), если точная версия 9.0.300 не установлена
    // - Это обеспечивает гибкость при получении патч-обновлений без изменения конфига
    "rollForward": "latestFeature"
  }
}
