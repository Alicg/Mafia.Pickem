{
  // Конфигурация глобального .NET SDK для всего проекта
  "sdk": {
    // Проект таргетит .NET 8, поэтому фиксируем 8.0 SDK,
    // совместимый и с локальной машиной, и с Azure Static Web Apps / Oryx build.
    "version": "8.0.100",
    
    // Стратегия выбора версии SDK:
    // - "latestFeature" позволяет использовать более новые версии в рамках 8.0.x
    //   (например, 8.0.3xx, 8.0.4xx), если точная версия 8.0.100 не установлена
    // - Это обеспечивает гибкость при получении патч-обновлений без изменения конфига
    "rollForward": "latestFeature"
  }
}
